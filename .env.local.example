# Supabase PostgreSQL Connection (runtime/serverless)
# Use the Supabase Transaction/Session Pooler URI in production (Vercel).
# Encode special characters in password: # -> %23, @ -> %40, ! -> %21
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Optional direct connection for Prisma migrations/introspection.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Supabase Anon Key (for client-side auth, optional)
NEXT_PUBLIC_SUPABASE_ANON_KEY="[your-anon-key]"

# Supabase Project URL (optional, for real-time features)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"

NODE_ENV=development
